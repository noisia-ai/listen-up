# Resend (https://resend.com) - API key del dominio verificado.
# Mientras no este configurada, /api/event-registration sigue funcionando
# pero omite el envio de correos (queda registrado en logs sin datos personales).
RESEND_API_KEY=

# Remitente verificado en Resend (requiere dominio verificado en Resend).
EVENT_FROM_EMAIL=ListenUp! <hola@listenuplatam.com>

# Correo interno que recibe la notificacion de cada nuevo registro.
EVENT_NOTIFY_EMAIL=fer@noisia.ai

# Reply-to del correo de confirmacion enviado al asistente.
EVENT_REPLY_TO=hola@listenuplatam.com

# Datos del evento (usados en el .ics y los correos).
EVENT_NAME=ListenUp! 5.0
EVENT_DATE=2026-08-13
EVENT_CITY=CDMX
EVENT_VENUE=Pata Negra Cuauhtémoc
EVENT_ADDRESS=Río Niagara 43, Cuauhtémoc, CDMX
